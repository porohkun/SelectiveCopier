<Window x:Class="SelectiveCopier.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:behaviors="clr-namespace:SelectiveCopier.Behaviors"
        xmlns:infrastructure="clr-namespace:SelectiveCopier.Infrastructure"
        xmlns:models="clr-namespace:SelectiveCopier.Models"
        xmlns:viewModels="clr-namespace:SelectiveCopier.ViewModels"
        mc:Ignorable="d"
        Title="SelectiveCopier"
        Width="{Binding MainViewWidth, Source={infrastructure:Resolve Type={x:Type models:AppSettings}}, Mode=TwoWay}"
        Height="{Binding MainViewHeight, Source={infrastructure:Resolve Type={x:Type models:AppSettings}}, Mode=TwoWay}"
        MinWidth="600"
        MinHeight="400"
        infrastructure:ViewModelLocator.ViewModel="{x:Type viewModels:MainViewModel}"
        d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <Style x:Key="RowLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="80" />
        </Style>

        <Style x:Key="RowButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="MinWidth" Value="80" />
        </Style>

        <!--  Невалидная регулярка подсвечивается, дерево при этом не трогается.  -->
        <Style x:Key="FilterTextBoxStyle" TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="4,3" />
            <!--  Дефолтный ToolTip задаём здесь, а не на элементе: локальное значение перебило бы DataTrigger.  -->
            <Setter Property="ToolTip" Value="Регулярное выражение. Применяется к именам файлов. Применить — кнопкой «Перечитать»." />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFileFilterValid}" Value="False">
                    <Setter Property="Background" Value="#FFFFE0E0" />
                    <Setter Property="BorderBrush" Value="#FFCC3333" />
                    <Setter Property="BorderThickness" Value="1.5" />
                    <Setter Property="ToolTip" Value="Некорректное регулярное выражение. Дерево не обновляется до исправления." />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <!--  Строка поиска влияет только на видимость и не затрагивает состояние чекбоксов.  -->
            <Setter Property="Visibility"
                    Value="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </Style>

        <HierarchicalDataTemplate x:Key="NodeTemplate"
                                  DataType="{x:Type viewModels:FileSystemNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="0,1">
                <CheckBox VerticalAlignment="Center"
                          IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          IsThreeState="{Binding IsDirectory, Mode=OneTime}" />
                <Image Width="16"
                       Height="16"
                       Margin="4,0"
                       VerticalAlignment="Center"
                       SnapsToDevicePixels="True">
                    <Image.Source>
                        <MultiBinding Converter="{StaticResource IconConverter}">
                            <Binding Path="FullPath" Mode="OneTime" />
                            <Binding Path="IsDirectory" Mode="OneTime" />
                        </MultiBinding>
                    </Image.Source>
                </Image>
                <TextBlock Text="{Binding Name, Mode=OneTime}" VerticalAlignment="Center" />
            </StackPanel>
        </HierarchicalDataTemplate>

    </Window.Resources>

    <Grid Margin="10" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Источник  -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Откуда:" Style="{StaticResource RowLabelStyle}" />

            <ComboBox Grid.Column="1"
                      IsEditable="True"
                      IsTextSearchEnabled="False"
                      VerticalContentAlignment="Center"
                      ItemsSource="{Binding RecentSources}"
                      behaviors:EditableComboBoxBehavior.UpdateSourceOnSelection="True"
                      Text="{Binding SourcePath, Mode=TwoWay, UpdateSourceTrigger=Explicit}" />

            <Button Grid.Column="2"
                    Content="Обзор"
                    Style="{StaticResource RowButtonStyle}"
                    Command="{Binding BrowseSourceCommand}" />

            <Button Grid.Column="3"
                    Content="Перечитать"
                    Style="{StaticResource RowButtonStyle}"
                    Command="{Binding RefreshCommand}" />
        </Grid>

        <!--  Цель  -->
        <Grid Grid.Row="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Куда:" Style="{StaticResource RowLabelStyle}" />

            <TextBox Grid.Column="1"
                     VerticalContentAlignment="Center"
                     Padding="4,3"
                     Text="{Binding TargetPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

            <Button Grid.Column="2"
                    Content="Обзор"
                    Style="{StaticResource RowButtonStyle}"
                    Command="{Binding BrowseTargetCommand}" />
        </Grid>

        <!--  Фильтр  -->
        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Фильтр:" Style="{StaticResource RowLabelStyle}" />

            <TextBox Grid.Column="1"
                     Style="{StaticResource FilterTextBoxStyle}"
                     Text="{Binding FileFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <!--  Поиск  -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Поиск:" Style="{StaticResource RowLabelStyle}" />

            <TextBox Grid.Column="1"
                     VerticalContentAlignment="Center"
                     Padding="4,3"
                     ToolTip="Скрывает несовпавшие файлы. На выбор не влияет."
                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=200}" />
        </Grid>

        <!--  Дерево  -->
        <TreeView Grid.Row="4"
                  ItemsSource="{Binding Nodes}"
                  ItemTemplate="{StaticResource NodeTemplate}"
                  ItemContainerStyle="{StaticResource TreeViewItemStyle}"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto" />

        <!--  Копирование  -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">

            <Button Content="Восстановить выбор из цели"
                    Padding="16,6"
                    Margin="0,0,8,0"
                    ToolTip="Отмечает файлы, которые уже лежат в папке-цели. Текущий выбор сбрасывается."
                    Command="{Binding RestoreSelectionCommand}" />

            <Button Content="Копировать"
                    MinWidth="120"
                    Padding="16,6"
                    Command="{Binding CopyCommand}" />

        </StackPanel>

    </Grid>
</Window>
